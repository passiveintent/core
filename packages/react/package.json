{
  "name": "@edgesignal/react",
  "version": "1.0.0",
  "description": "React wrapper for @edgesignal/core — drop-in useEdgeSignal hook for Next.js and React apps.",
  "keywords": [
    "intent",
    "analytics",
    "react",
    "next.js",
    "privacy",
    "markov-chain",
    "churn-prevention",
    "zero-egress",
    "gdpr",
    "behavioral-analytics"
  ],
  "author": "Purushottam <purushpsm147@yahoo.co.in> (https://github.com/purushpsm147)",
  "license": "AGPL-3.0-only",
  "repository": {
    "type": "git",
    "url": "https://github.com/purushpsm147/EdgeSignal-Privacy-First-Intent-Engine.git",
    "directory": "packages/react"
  },
  "homepage": "https://github.com/purushpsm147/EdgeSignal-Privacy-First-Intent-Engine#readme",
  "engines": {
    "node": ">=20"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --sourcemap",
    "typecheck": "tsc --noEmit",
    "clean": "node -e \"require('fs').rmSync('dist', { recursive: true, force: true })\""
  },
  "dependencies": {
    "@edgesignal/core": "*"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "peerDependenciesMeta": {
    "react-dom": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "typescript": "^5.6.3",
    "tsup": "^8.5.1"
  }
}
